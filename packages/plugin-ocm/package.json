{
  "name": "@kubernaut/plugin-ocm",
  "version": "0.1.0",
  "description": "OCP console dynamic plugin for Kubernaut",
  "private": true,
  "consolePlugin": {
    "name": "kubernaut-console-plugin",
    "version": "0.1.0",
    "displayName": "Kubernaut",
    "description": "AI-powered Kubernetes incident response console",
    "exposedModules": {
      "KubernautPage": "./src/components/KubernautPage"
    },
    "dependencies": {
      "@console/pluginAPI": "*"
    }
  },
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "start": "webpack serve --mode development",
