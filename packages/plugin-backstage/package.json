{
  "name": "@kubernaut/plugin-backstage",
  "version": "0.1.0",
  "description": "Backstage frontend plugin for Kubernaut Console",
  "backstage": {
    "role": "frontend-plugin"
  },
  "exports": {
    ".": "./src/index.ts",
    "./alpha": "./src/alpha.tsx",
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "alpha": [
        "src/alpha.tsx"
      ],
      "package.json": [
        "package.json"
      ]
    }
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "backstage-cli package build --module-federation",
    "bundle": "./scripts/bundle-dynamic.sh",
    "verify-bundle": "./scripts/verify-bundle.sh",
    "test": "vitest run",
    "lint": "backstage-cli package lint",
    "clean": "backstage-cli package clean"
  },
  "dependencies": {
    "@backstage/core-components": "^0.18.11",
    "@backstage/core-plugin-api": "^1.12.7",
    "@backstage/frontend-plugin-api": "^0.17.2",
    "@kubernaut/ui-core": "workspace:*",
    "react-use": "^17.5.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.3",
    "@backstage/dev-utils": "^1.1.24",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "jsdom": "^26.1.0",
    "vitest": "^3.2.1"
  },
  "configSchema": "config.d.ts"
}
