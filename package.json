{
  "name": "kubernaut-demo-console",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "dev": "turbo run dev --filter @kubernaut/standalone",
    "lint": "turbo run lint",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "test:visual": "npx playwright test e2e/visual.spec.ts",
    "test:visual:update": "npx playwright test e2e/visual.spec.ts --update-snapshots"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@patternfly/chatbot": "^6.6.0",
    "@patternfly/react-core": "^6.5.1",
    "@patternfly/react-icons": "^6.5.1",
    "@playwright/test": "^1.61.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@storybook/test": "^8.6.15",
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "http-server": "^14.1.1",
    "playwright": "^1.61.0",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.3.1",
    "turbo": "^2.9.18",
    "wait-on": "^9.0.10"
  }
}
